.ct-hiw-title { font-size: var(--text-lg); font-weight: var(--font-semibold); letter-spacing: var(--tracking-normal); text-transform: uppercase; color: var(--text-primary); margin-bottom: 12px; font-family: var(--font-body); }
.ct-hiw-desc { font-size: var(--text-sm); font-weight: var(--font-light); color: var(--text-secondary); line-height: var(--leading-relaxed); font-family: var(--font-body); }

/* ── PRODUCT GRID ── */
.ct-products { background: var(--bg-secondary); }
.ct-prod-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 2px; }
.ct-prod-card {
