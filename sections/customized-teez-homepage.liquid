  flex-direction: column;
  justify-content: flex-end;
  padding: 28px;
  z-index: 2;
  border-radius: 8px;
}
.ct-cat-label { font-size: var(--text-xs); font-weight: var(--font-semibold); letter-spacing: var(--tracking-widest); text-transform: uppercase; color: var(--accent-primary); margin-bottom: 6px; font-family: var(--font-body); }
.ct-cat-name {
  font-family: var(--font-display);
  font-size: var(--text-3xl);
  letter-spacing: var(--tracking-normal);
  text-transform: uppercase;
  color: var(--text-inverse);
  line-height: var(--leading-tight);
