  }
  .ct-coll-count {
    font-size: 12px;
    white-space: nowrap;
  }
  .ct-coll-arrow {
    opacity: 1;
    transform: none;
    font-size: 16px;
  }

  /* Enhanced mobile hero */
  @media (max-width: 480px) {
    .ct-hero-left {
      padding: 40px 20px;
    }

    .ct-eyebrow {
      font-size: 10px;
      letter-spacing: 3px;
