  border: 1px solid var(--border-primary);
  color: var(--text-primary);
}

.ct-prod-action-btn.secondary:hover {
  border-color: var(--accent-primary);
  color: var(--accent-primary);
  background: var(--accent-light);
}

/* Product stock indicator */
.ct-prod-stock {
