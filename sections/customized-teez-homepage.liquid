  .ct-cta { flex-direction: column; padding: 64px 28px; margin: 0 20px; }
  .ct-section-header-row { flex-direction: column; align-items: flex-start; gap: 16px; }
  .ct-hero-stats { gap: 28px; }

  /* ── CATALOG LIST MOBILE FIX ── */
  .ct-coll-row {
    align-items: center;
    padding: 18px 0;
    gap: 0;
  }
  .ct-coll-left {
    gap: 10px;
