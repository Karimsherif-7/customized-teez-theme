.ct-coll-name { font-family: var(--font-display); font-size: clamp(28px, 3.5vw, 48px); letter-spacing: var(--tracking-wide); text-transform: uppercase; color: var(--text-primary); transition: color .3s; font-weight: var(--font-bold); line-height: var(--leading-tight); }
.ct-coll-tag { font-size: var(--text-xs); letter-spacing: var(--tracking-wide); text-transform: uppercase; color: var(--text-muted); background: var(--border-primary); padding: 4px 12px; border-radius: 4px; font-family: var(--font-body); font-weight: var(--font-medium); }
