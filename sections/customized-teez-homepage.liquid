/* ── HOW IT WORKS ── */
.ct-hiw { background: var(--bg-primary); }
.ct-hiw-header { text-align: center; margin-bottom: 72px; }
.ct-hiw-header .ct-section-tag { justify-content: center; }
.ct-hiw-header .ct-section-tag::before { display: none; }
.ct-hiw-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1px; background: var(--border-primary); }
.ct-hiw-step { background: var(--bg-primary); padding: 48px 36px; position: relative; overflow: hidden; border-radius: 8px; }
.ct-hiw-step::before {
