.ct-testi-name { font-size: var(--text-base); font-weight: var(--font-semibold); color: var(--text-primary); letter-spacing: var(--tracking-normal); font-family: var(--font-body); }
.ct-testi-loc { font-size: var(--text-sm); color: var(--text-muted); letter-spacing: var(--tracking-normal); font-family: var(--font-body); font-weight: var(--font-normal); }

/* ── MARQUEE 2 ── */
.ct-marquee2-wrap { overflow: hidden; background: var(--bg-primary); border-top: 1px solid var(--border-primary); border-bottom: 1px solid var(--border-primary); padding: 12px 0; white-space: nowrap; }
.ct-marquee2-track { display: inline-flex; animation: ct-marquee2 28s linear infinite; }
@keyframes ct-marquee2 { from { transform: translateX(-50%); } to { transform: translateX(0); } }

/* ── SCROLL REVEAL ── */
.ct-reveal {
  opacity: 0;
  transform: translateY(30px);
  transition: opacity 0.8s cubic-bezier(0.4, 0, 0.2, 1), transform 0.8s cubic-bezier(0.4, 0, 0.2, 1);
}

.ct-reveal.ct-visible {
  opacity: 1;
  transform: translateY(0);
}

.ct-d1 { transition-delay: 0.1s; }
.ct-d2 { transition-delay: 0.2s; }
.ct-d3 { transition-delay: 0.3s; }

/* Staggered animations for grids */
.ct-cat-grid .ct-reveal:nth-child(1) { transition-delay: 0.1s; }
.ct-cat-grid .ct-reveal:nth-child(2) { transition-delay: 0.2s; }
.ct-cat-grid .ct-reveal:nth-child(3) { transition-delay: 0.3s; }
.ct-cat-grid .ct-reveal:nth-child(4) { transition-delay: 0.4s; }
.ct-cat-grid .ct-reveal:nth-child(5) { transition-delay: 0.5s; }
.ct-cat-grid .ct-reveal:nth-child(6) { transition-delay: 0.6s; }

.ct-prod-grid .ct-reveal:nth-child(1) { transition-delay: 0.1s; }
.ct-prod-grid .ct-reveal:nth-child(2) { transition-delay: 0.2s; }
.ct-prod-grid .ct-reveal:nth-child(3) { transition-delay: 0.3s; }
.ct-prod-grid .ct-reveal:nth-child(4) { transition-delay: 0.4s; }

.ct-hiw-grid .ct-reveal:nth-child(1) { transition-delay: 0.1s; }
.ct-hiw-grid .ct-reveal:nth-child(2) { transition-delay: 0.2s; }
.ct-hiw-grid .ct-reveal:nth-child(3) { transition-delay: 0.3s; }
.ct-hiw-grid .ct-reveal:nth-child(4) { transition-delay: 0.4s; }

.ct-testi-grid .ct-reveal:nth-child(1) { transition-delay: 0.1s; }
.ct-testi-grid .ct-reveal:nth-child(2) { transition-delay: 0.2s; }
.ct-testi-grid .ct-reveal:nth-child(3) { transition-delay: 0.3s; }

.ct-coll-list .ct-reveal:nth-child(1) { transition-delay: 0.1s; }
.ct-coll-list .ct-reveal:nth-child(2) { transition-delay: 0.2s; }
.ct-coll-list .ct-reveal:nth-child(3) { transition-delay: 0.3s; }
.ct-coll-list .ct-reveal:nth-child(4) { transition-delay: 0.4s; }
.ct-coll-list .ct-reveal:nth-child(5) { transition-delay: 0.5s; }
.ct-coll-list .ct-reveal:nth-child(6) { transition-delay: 0.6s; }

/* Back to top button */
.ct-back-to-top {
  position: fixed;
  bottom: 30px;
  right: 30px;
  width: 50px;
  height: 50px;
  background: var(--accent-primary);
  color: var(--bg-dark);
  border: none;
  border-radius: 50%;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20px;
  opacity: 0;
  visibility: hidden;
  transform: translateY(20px);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  z-index: 999;
  box-shadow: 0 4px 15px rgba(201, 168, 76, 0.4);
}

.ct-back-to-top.visible {
  opacity: 1;
  visibility: visible;
  transform: translateY(0);
}

.ct-back-to-top:hover {
  background: var(--accent-secondary);
  transform: translateY(-4px);
  box-shadow: 0 8px 25px rgba(201, 168, 76, 0.5);
}

.ct-back-to-top:active {
  transform: translateY(-2px);
}

/* Enhanced cursor states */
.ct-page {
  cursor: default;
}

.ct-page a,
.ct-page button {
  cursor: pointer;
}

/* Smooth scrolling */
.ct-page {
  scroll-behavior: smooth;
}

/* Selection styling */
.ct-page::selection {
  background: var(--accent-primary);
  color: var(--bg-dark);
}

.ct-page ::-moz-selection {
  background: var(--accent-primary);
  color: var(--bg-dark);
}

/* Enhanced focus states */
.ct-page a:focus-visible,
.ct-page button:focus-visible {
  outline: 2px solid var(--accent-primary);
  outline-offset: 2px;
  border-radius: 4px;
}

/* Loading skeleton animation */
.ct-skeleton {
  background: linear-gradient(90deg, var(--bg-secondary) 25%, var(--bg-tertiary) 50%, var(--bg-secondary) 75%);
  background-size: 200% 100%;
  animation: skeleton-loading 1.5s infinite;
  border-radius: 4px;
}

@keyframes skeleton-loading {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

/* Progress bar animation */
.ct-progress-bar {
  height: 3px;
  background: var(--accent-light);
  border-radius: 2px;
  overflow: hidden;
  position: relative;
}

.ct-progress-bar::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  height: 100%;
  background: var(--accent-primary);
  width: 0;
  transition: width 0.3s ease;
}

/* Ripple effect for buttons */
.ct-ripple {
  position: absolute;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.4);
  transform: scale(0);
  animation: ripple 0.6s linear;
  pointer-events: none;
}

@keyframes ripple {
  to {
    transform: scale(4);
    opacity: 0;
  }
}

/* Magnetic button effect */
.ct-magnetic {
  transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

/* Parallax effect for hero */
.ct-hero-right {
  perspective: 1000px;
}

.ct-hero-img-box {
  transform-style: preserve-3d;
  transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
}

.ct-hero-right:hover .ct-hero-img-box {
  transform: rotateY(5deg) rotateX(5deg);
}

/* Glow effect on hover */
.ct-glow-on-hover {
  transition: box-shadow 0.3s ease;
}

.ct-glow-on-hover:hover {
  box-shadow: 0 0 30px rgba(201, 168, 76, 0.4);
}

/* Text highlight effect */
.ct-text-highlight {
  position: relative;
  display: inline-block;
}

.ct-text-highlight::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  width: 0;
  height: 3px;
  background: var(--accent-primary);
  transition: width 0.3s ease;
}

.ct-text-highlight:hover::after {
  width: 100%;
}

/* Shake animation for attention */
.ct-shake {
  animation: shake 0.5s ease-in-out;
}

@keyframes shake {
  0%, 100% { transform: translateX(0); }
  10%, 30%, 50%, 70%, 90% { transform: translateX(-2px); }
  20%, 40%, 60%, 80% { transform: translateX(2px); }
}

/* Bounce animation */
.ct-bounce {
  animation: bounce 0.5s ease;
}

@keyframes bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-10px); }
}

/* Scale animation */
.ct-scale-in {
  animation: scaleIn 0.3s ease;
}

@keyframes scaleIn {
  from {
    opacity: 0;
    transform: scale(0.9);
  }
  to {
    opacity: 1;
    transform: scale(1);
  }
}

/* Rotate animation */
.ct-rotate {
  animation: rotate 0.5s ease;
}

@keyframes rotate {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

/* ── INTERACTIVE ELEMENTS ── */

/* Enhanced button interactions */
.ct-btn-primary {
  position: relative;
  overflow: hidden;
  transform: translateY(0);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.ct-btn-primary::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 0;
  height: 0;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.3);
  transform: translate(-50%, -50%);
  transition: width 0.6s ease, height 0.6s ease;
}

.ct-btn-primary:hover::before {
  width: 300px;
  height: 300px;
}

.ct-btn-primary:active {
  transform: translateY(-1px) scale(0.98);
}

/* Card hover effects */
.ct-cat-card {
  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  transform: translateY(0);
}

.ct-cat-card:hover {
  transform: translateY(-8px) scale(1.02);
  box-shadow: 0 20px 40px rgba(0, 0, 0, 0.15);
}

.ct-cat-card:active {
  transform: translateY(-4px) scale(1.01);
}

/* Product card interactions */
.ct-prod-card {
  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  transform: translateY(0);
}

.ct-prod-card:hover {
  transform: translateY(-8px);
  box-shadow: 0 20px 40px rgba(0, 0, 0, 0.12);
}

.ct-prod-card:active {
  transform: translateY(-4px);
}

/* Enhanced image hover */
.ct-cat-img img,
.ct-prod-img-inner img {
  transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
}

.ct-cat-card:hover .ct-cat-img img,
.ct-prod-card:hover .ct-prod-img-inner img {
  transform: scale(1.08);
}

/* Link hover effects */
.ct-view-all {
  position: relative;
  transition: all 0.3s ease;
}

.ct-view-all::after {
  content: '';
  position: absolute;
  right: -20px;
  top: 50%;
  width: 0;
  height: 2px;
  background: var(--accent-primary);
  transition: all 0.3s ease;
  transform: translateY(-50%);
}

.ct-view-all:hover::after {
  right: -28px;
  width: 20px;
}

/* Catalog row interactions */
.ct-coll-row {
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
}

.ct-coll-row::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 4px;
  background: var(--accent-primary);
  transform: scaleY(0);
  transition: transform 0.3s ease;
  border-radius: 4px 0 0 4px;
}

.ct-coll-row:hover::before {
  transform: scaleY(1);
}

/* Testimonial card interactions */
.ct-testi-card {
  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  transform: translateY(0);
}

.ct-testi-card:hover {
  transform: translateY(-8px);
  box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
}

/* Enhanced swatch interactions */
.ct-swatch {
  transition: all 0.3s ease;
  cursor: pointer;
  position: relative;
}

.ct-swatch::after {
  content: '';
  position: absolute;
  inset: -4px;
  border: 2px solid var(--accent-primary);
  border-radius: 50%;
  opacity: 0;
  transform: scale(0.8);
  transition: all 0.3s ease;
}

.ct-swatch:hover::after {
  opacity: 1;
  transform: scale(1);
}

/* Star rating interactions */
.ct-star {
  transition: all 0.3s ease;
  cursor: pointer;
}

.ct-star:hover {
  transform: scale(1.2);
  filter: brightness(1.2);
}

/* Enhanced navigation interactions */
.ct-nav-links a {
  position: relative;
  overflow: hidden;
}

.ct-nav-links a::before {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 2px;
  background: var(--accent-primary);
  transform: translateX(-100%);
  transition: transform 0.3s ease;
}

.ct-nav-links a:hover::before {
  transform: translateX(0);
}

/* Icon interactions */
.ct-nav-icon {
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.ct-nav-icon:hover {
  transform: rotate(15deg) scale(1.1);
}

/* Badge interactions */
.ct-prod-badge {
  transition: all 0.3s ease;
  cursor: default;
}

.ct-prod-badge:hover {
  transform: scale(1.05);
  box-shadow: 0 4px 12px rgba(201, 168, 76, 0.3);
}

/* Enhanced marquee interactions */
.ct-marquee-wrap:hover {
  background: var(--accent-secondary);
}

.ct-marquee-wrap:hover .ct-marquee-track {
  animation-duration: 18s;
}

/* CTA interactions */
.ct-cta {
  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  transform: translateY(0);
}

.ct-cta:hover {
  transform: translateY(-4px);
  box-shadow: 0 20px 50px rgba(201, 168, 76, 0.3);
}

.ct-cta:active {
  transform: translateY(-2px);
}

/* Focus states for accessibility */
.ct-btn-primary:focus,
.ct-btn-ghost:focus,
.ct-nav-links a:focus,
.ct-view-all:focus {
  outline: 2px solid var(--accent-primary);
  outline-offset: 2px;
}

/* Loading states */
.ct-btn-primary.loading,
.ct-btn-dark.loading {
  position: relative;
  pointer-events: none;
  opacity: 0.7;
}

.ct-btn-primary.loading::after,
.ct-btn-dark.loading::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 16px;
  height: 16px;
  border: 2px solid transparent;
  border-top-color: var(--bg-dark);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  transform: translate(-50%, -50%);
}

@keyframes spin {
  to { transform: translate(-50%, -50%) rotate(360deg); }
}

/* Success/error states */
.ct-btn-primary.success {
  background: var(--success);
  color: var(--text-inverse);
}

.ct-btn-primary.error {
  background: var(--error);
  color: var(--text-inverse);
}

/* Touch feedback for mobile */
@media (hover: none) and (pointer: coarse) {
  .ct-btn-primary:active,
  .ct-btn-ghost:active,
  .ct-cat-card:active,
  .ct-prod-card:active,
  .ct-testi-card:active {
    transform: scale(0.98);
    opacity: 0.8;
  }

  .ct-nav-icon:active {
    transform: scale(0.95);
    background: var(--accent-light);
  }
}
.ct-reveal { opacity: 0; transform: translateY(24px); transition: opacity .7s ease, transform .7s ease; }
.ct-reveal.ct-visible { opacity: 1; transform: translateY(0); }
.ct-d1 { transition-delay: .1s; }
.ct-d2 { transition-delay: .2s; }
.ct-d3 { transition-delay: .3s; }

/* ── RESPONSIVE ── */
@media (max-width: 960px) {
