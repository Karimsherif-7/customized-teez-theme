}
.ct-cat-card:nth-child(1) .ct-cat-name { font-size: var(--text-5xl); }
.ct-cat-count { font-size: var(--text-sm); color: rgba(255,255,255,.6); letter-spacing: var(--tracking-normal); margin-top: 4px; font-family: var(--font-body); font-weight: var(--font-normal); }
.ct-cat-arrow {
