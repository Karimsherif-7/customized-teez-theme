{% comment %}
  Customized Tees — Custom Homepage Section
  Full dark streetwear landing page with all real Shopify product links
{% endcomment %}

<style>
/* ── RESET & VARS ── */
.ct-page *, .ct-page *::before, .ct-page *::after { box-sizing: border-box; margin: 0; padding: 0; }
.ct-page {
  --black: #FFFFFF;
  --off-black: #FAF7F0;
  --card: #F5F0E8;
  --card2: #EDE5D0;
  --border: #E8D9B0;
  --border2: #DDD0A8;
  --accent: #C9A84C;
  --accent2: rgba(201,168,76,0.08);
  --white: #1A1A1A;
  --muted: #555555;
  --muted2: #888888;
  background: var(--black);
  color: var(--white);
  font-family: 'Barlow', 'Helvetica Neue', Arial, sans-serif;
  overflow-x: hidden;

}

/* ── CUSTOM NAV BAR ── */
.ct-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 48px;
  height: 70px;
  background: rgba(237, 219, 169, 0.98);
  border-bottom: 1px solid var(--border);
}
.ct-nav-logo {
  font-family: 'Bebas Neue', Impact, sans-serif;
  font-size: 24px;
  letter-spacing: 3px;
  color: var(--white);
  text-decoration: none;
  flex-shrink: 0;
}
.ct-nav-logo span { color: var(--accent); }
.ct-nav-links { display: flex; gap: 32px; }
.ct-nav-links a {
  font-size: 12px;
  font-weight: 600;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--muted);
  text-decoration: none;
  transition: color .2s;
}
.ct-nav-links a:hover { color: var(--white); }
.ct-nav-cta {
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 2.5px;
  text-transform: uppercase;
  padding: 9px 22px;
  background: var(--accent);
  color: var(--black);
  text-decoration: none;
  transition: opacity .2s;
  flex-shrink: 0;
}
.ct-nav-cta:hover { opacity: .85; }
.ct-nav-icon {
  width: 32px;
  height: 32px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  color: var(--muted);
  text-decoration: none;
  margin-left: 10px;
  transition: color .2s, opacity .2s;
}
.ct-nav-icon:hover { color: var(--white); opacity: .85; }
@media (max-width: 960px) {
  .ct-nav { padding: 0 20px; }
  .ct-nav-links { display: none; }
}
.ct-nav-actions {
  display: flex;
  align-items: center;
  gap: 4px;
  flex-shrink: 0;
}

/* ── HERO ── */
.ct-hero {
  min-height: 100vh;
  display: grid;
  grid-template-columns: 1fr 1fr;
  position: relative;
  overflow: hidden;
}
.ct-hero-left {
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 80px 60px 80px 80px;
  background: var(--off-black);
  z-index: 2;
}
.ct-eyebrow {
  display: flex;
  align-items: center;
  gap: 10px;
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 4px;
  text-transform: uppercase;
  color: var(--accent);
  margin-bottom: 28px;
}
.ct-eyebrow::before { content: ''; width: 28px; height: 1px; background: var(--accent); }
.ct-hero-title {
  font-family: 'Bebas Neue', 'Impact', sans-serif;
  font-size: clamp(72px, 9vw, 120px);
  line-height: 0.9;
  letter-spacing: 2px;
  text-transform: uppercase;
  margin-bottom: 28px;
  color: var(--white);
}
.ct-hero-title .ct-accent { color: var(--accent); display: block; }
.ct-hero-title .ct-outline { display: block; -webkit-text-stroke: 1px var(--white); color: transparent; }
.ct-hero-sub {
  font-size: 16px;
  font-weight: 300;
  color: var(--muted2);
  line-height: 1.8;
  max-width: 400px;
  margin-bottom: 44px;
}
.ct-hero-btns { display: flex; align-items: center; gap: 24px; flex-wrap: wrap; }
.ct-btn-primary {
  display: inline-block;
  font-size: 13px;
  font-weight: 700;
  letter-spacing: 3px;
  text-transform: uppercase;
  padding: 16px 40px;
  background: var(--accent);
  color: var(--black);
  text-decoration: none;
  transition: opacity .2s, transform .15s;
}
.ct-btn-primary:hover { opacity: .88; transform: translateY(-2px); }
.ct-btn-ghost {
  font-size: 13px;
  font-weight: 600;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--white);
  text-decoration: none;
  border-bottom: 1px solid var(--muted);
  padding-bottom: 2px;
  transition: color .2s, border-color .2s;
}
.ct-btn-ghost:hover { color: var(--accent); border-color: var(--accent); }
.ct-hero-stats {
  display: flex;
  gap: 44px;
  margin-top: 56px;
  padding-top: 36px;
  border-top: 1px solid var(--border);
}
.ct-stat-val {
  font-family: 'Bebas Neue', Impact, sans-serif;
  font-size: 38px;
  color: var(--white);
  letter-spacing: 1px;
  line-height: 1;
}
.ct-stat-label {
  font-size: 11px;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--muted);
  margin-top: 4px;
}
.ct-hero-right {
  position: relative;
  background: var(--black);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}
.ct-hero-right::before {
  content: '';
  position: absolute;
  left: 0; top: 0; bottom: 0; width: 1px;
  background: linear-gradient(to bottom, transparent, var(--accent), transparent);
  opacity: .25;
}
.ct-hero-img-box {
  width: 340px;
  height: 420px;
  background: var(--card);
  border: 1px dashed var(--border2);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 10px;
  position: relative;
  overflow: hidden;
}
.ct-hero-img-box img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
.ct-hero-img-hint {
  font-size: 10px;
  letter-spacing: 3px;
  color: var(--border2);
  text-transform: uppercase;
  position: relative;
  z-index: 1;
}
.ct-hero-badge {
  position: absolute;
  bottom: 120px;
  right: 24px;
  background: var(--accent);
  color: var(--black);
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 2px;
  padding: 6px 14px;
  text-transform: uppercase;
  z-index: 2;
}
.ct-hero-label { position: absolute; bottom: 28px; left: 28px; }
.ct-hero-label-sm { font-size: 10px; letter-spacing: 3px; text-transform: uppercase; color: var(--muted); }
.ct-hero-label-lg {
  font-family: 'Bebas Neue', Impact, sans-serif;
  font-size: 52px;
  color: var(--border);
  line-height: 1;
  user-select: none;
}

/* ── MARQUEE ── */
.ct-marquee-wrap { overflow: hidden; background: var(--accent); padding: 12px 0; white-space: nowrap; }
.ct-marquee-track { display: inline-flex; animation: ct-marquee 22s linear infinite; }
.ct-marquee-item {
  font-family: 'Bebas Neue', Impact, sans-serif;
  font-size: 15px;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: var(--black);
  padding: 0 30px;
}
.ct-marquee-sep { color: rgba(0,0,0,.3); }
@keyframes ct-marquee { from { transform: translateX(0); } to { transform: translateX(-50%); } }

/* ── SECTION COMMON ── */
.ct-section { padding: 96px 80px; }
.ct-section-tag {
  display: flex;
  align-items: center;
  gap: 10px;
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 4px;
  text-transform: uppercase;
  color: var(--accent);
  margin-bottom: 14px;
}
.ct-section-tag::before { content: ''; width: 22px; height: 1px; background: var(--accent); }
.ct-section-title {
  font-family: 'Bebas Neue', Impact, sans-serif;
  font-size: clamp(48px, 5.5vw, 72px);
  letter-spacing: 2px;
  text-transform: uppercase;
  line-height: .95;
  color: var(--white);
}
.ct-section-header-row {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin-bottom: 52px;
}
.ct-view-all {
  font-size: 12px;
  font-weight: 600;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--accent);
  text-decoration: none;
  display: flex;
  align-items: center;
  gap: 6px;
  white-space: nowrap;
  transition: gap .2s;
}
.ct-view-all:hover { gap: 14px; }

/* ── CATEGORIES ── */
.ct-categories { background: var(--off-black); }
.ct-cat-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 2px; }
.ct-cat-card {
  position: relative;
  background: var(--card);
  overflow: hidden;
  aspect-ratio: 3/4;
  text-decoration: none;
  display: block;
}
.ct-cat-card:nth-child(1) { grid-column: span 2; aspect-ratio: auto; min-height: 480px; }
.ct-cat-img {
  width: 100%; height: 100%;
  background: var(--card2);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform .6s ease;
  position: relative;
}
.ct-cat-img img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; transition: transform .6s ease; }
.ct-cat-img-hint { font-size: 9px; letter-spacing: 3px; color: var(--border2); text-transform: uppercase; position: relative; z-index: 1; }
.ct-cat-card:hover .ct-cat-img { transform: scale(1.04); }
.ct-cat-card:hover .ct-cat-img img { transform: scale(1.04); }
.ct-cat-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(0,0,0,.85) 0%, transparent 55%);
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  padding: 28px;
  z-index: 2;
}
.ct-cat-label { font-size: 11px; font-weight: 600; letter-spacing: 3px; text-transform: uppercase; color: var(--accent); margin-bottom: 6px; }
.ct-cat-name {
  font-family: 'Bebas Neue', Impact, sans-serif;
  font-size: 32px;
  letter-spacing: 1px;
  text-transform: uppercase;
  color: var(--white);
  line-height: 1;
}
.ct-cat-card:nth-child(1) .ct-cat-name { font-size: 52px; }
.ct-cat-count { font-size: 12px; color: rgba(255,255,255,.4); letter-spacing: 1px; margin-top: 4px; }
.ct-cat-arrow {
  position: absolute;
  top: 20px; right: 20px;
  width: 36px; height: 36px;
  background: var(--accent);
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transform: scale(.8);
  transition: opacity .3s, transform .3s;
  font-size: 16px;
  color: var(--black);
  font-weight: 700;
  z-index: 3;
}
.ct-cat-card:hover .ct-cat-arrow { opacity: 1; transform: scale(1); }

/* ── HOW IT WORKS ── */
.ct-hiw { background: var(--black); }
.ct-hiw-header { text-align: center; margin-bottom: 72px; }
.ct-hiw-header .ct-section-tag { justify-content: center; }
.ct-hiw-header .ct-section-tag::before { display: none; }
.ct-hiw-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1px; background: var(--border); }
.ct-hiw-step { background: var(--black); padding: 48px 36px; position: relative; overflow: hidden; }
.ct-hiw-step::before {
  content: attr(data-n);
  font-family: 'Bebas Neue', Impact, sans-serif;
  font-size: 100px;
  color: rgba(232,255,0,.04);
  position: absolute;
  top: -10px; right: 16px;
  line-height: 1;
  pointer-events: none;
}
.ct-hiw-num {
  font-family: 'Bebas Neue', Impact, sans-serif;
  font-size: 56px;
  color: var(--accent);
  line-height: 1;
  margin-bottom: 18px;
  letter-spacing: 2px;
}
.ct-hiw-title { font-size: 18px; font-weight: 600; letter-spacing: 1px; text-transform: uppercase; color: var(--white); margin-bottom: 12px; }
.ct-hiw-desc { font-size: 14px; font-weight: 300; color: var(--muted2); line-height: 1.8; }

/* ── PRODUCT GRID ── */
.ct-products { background: var(--off-black); }
.ct-prod-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 2px; }
.ct-prod-card { background: var(--card); position: relative; overflow: hidden; text-decoration: none; display: block; }
.ct-prod-card:hover .ct-prod-img-inner { transform: scale(1.05); }
.ct-prod-card:hover .ct-prod-overlay { opacity: 1; }
.ct-prod-img { aspect-ratio: 3/4; overflow: hidden; background: var(--card2); position: relative; }
.ct-prod-img-inner { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; transition: transform .5s ease; position: relative; }
.ct-prod-img-inner img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
.ct-prod-img-hint { font-size: 9px; letter-spacing: 3px; color: var(--border2); text-transform: uppercase; position: relative; z-index: 1; }
.ct-prod-overlay { position: absolute; inset: 0; background: rgba(232,255,0,.05); display: flex; align-items: flex-end; padding: 16px; opacity: 0; transition: opacity .3s; z-index: 2; }
.ct-prod-overlay-btn { font-size: 11px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; padding: 10px 0; background: var(--accent); color: var(--black); width: 100%; text-align: center; text-decoration: none; display: block; }
.ct-prod-info { padding: 16px 18px 20px; border-top: 1px solid var(--border); }
.ct-prod-badge { display: inline-block; font-size: 9px; font-weight: 700; letter-spacing: 2.5px; text-transform: uppercase; padding: 3px 8px; background: var(--accent2); color: var(--accent); margin-bottom: 8px; }
.ct-prod-name { font-size: 15px; font-weight: 600; letter-spacing: .5px; color: var(--white); margin-bottom: 6px; }
.ct-prod-colors { display: flex; gap: 5px; margin-bottom: 10px; }
.ct-swatch { width: 12px; height: 12px; border-radius: 50%; border: 1px solid var(--border2); }
.ct-prod-price { font-family: 'Bebas Neue', Impact, sans-serif; font-size: 22px; color: var(--accent); letter-spacing: 1px; }
.ct-prod-price-orig { font-size: 13px; color: var(--muted); text-decoration: line-through; margin-left: 8px; }

/* ── CATALOG LIST ── */
.ct-catalog { background: var(--black); }
.ct-coll-list { display: flex; flex-direction: column; }
.ct-coll-row { display: flex; align-items: center; justify-content: space-between; padding: 26px 0; border-top: 1px solid var(--border); text-decoration: none; transition: padding-left .3s; }
.ct-coll-row:last-child { border-bottom: 1px solid var(--border); }
.ct-coll-row:hover { padding-left: 16px; }
.ct-coll-row:hover .ct-coll-name { color: var(--accent); }
.ct-coll-row:hover .ct-coll-arrow { opacity: 1; transform: translateX(0); }
.ct-coll-left { display: flex; align-items: center; gap: 20px; }
.ct-coll-num { font-size: 12px; color: var(--muted); letter-spacing: 2px; width: 28px; }
.ct-coll-name { font-family: 'Bebas Neue', Impact, sans-serif; font-size: clamp(28px, 3.5vw, 48px); letter-spacing: 2px; text-transform: uppercase; color: var(--white); transition: color .3s; }
.ct-coll-tag { font-size: 11px; letter-spacing: 2px; text-transform: uppercase; color: var(--muted); background: var(--border); padding: 4px 12px; }
.ct-coll-right { display: flex; align-items: center; gap: 20px; }
.ct-coll-count { font-size: 13px; color: var(--muted); letter-spacing: 1px; }
.ct-coll-arrow { font-size: 20px; color: var(--accent); opacity: 0; transform: translateX(-8px); transition: opacity .3s, transform .3s; }

/* ── CTA BANNER ── */
.ct-cta { padding: 100px 80px; background: var(--accent); display: flex; align-items: center; justify-content: space-between; gap: 40px; position: relative; overflow: hidden; }
.ct-cta::before { content: 'CUSTOMIZE'; font-family: 'Bebas Neue', Impact, sans-serif; font-size: 240px; color: rgba(0,0,0,.055); position: absolute; left: -30px; top: 50%; transform: translateY(-50%); white-space: nowrap; letter-spacing: 12px; pointer-events: none; }
.ct-cta-content { position: relative; z-index: 2; }
.ct-cta-title { font-family: 'Bebas Neue', Impact, sans-serif; font-size: clamp(44px, 5.5vw, 80px); line-height: .95; letter-spacing: 2px; text-transform: uppercase; color: var(--black); margin-bottom: 14px; }
.ct-cta-sub { font-size: 16px; color: rgba(0,0,0,.55); max-width: 440px; font-weight: 300; }
.ct-btn-dark { font-size: 13px; font-weight: 700; letter-spacing: 3px; text-transform: uppercase; padding: 20px 52px; background: var(--black); color: var(--accent); text-decoration: none; transition: opacity .2s; display: inline-block; white-space: nowrap; position: relative; z-index: 2; flex-shrink: 0; }
.ct-btn-dark:hover { opacity: .88; }

/* ── TESTIMONIALS ── */
.ct-testimonials { background: var(--off-black); }
.ct-testi-header { text-align: center; margin-bottom: 60px; }
.ct-testi-header .ct-section-tag { justify-content: center; }
.ct-testi-header .ct-section-tag::before { display: none; }
.ct-testi-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2px; }
.ct-testi-card { background: var(--card); padding: 44px 36px; border: 1px solid var(--border); position: relative; overflow: hidden; }
.ct-testi-card::before { content: '"'; font-family: 'Bebas Neue', Impact, sans-serif; font-size: 140px; color: var(--accent); opacity: .05; position: absolute; top: -20px; left: 16px; line-height: 1; pointer-events: none; }
.ct-stars { display: flex; gap: 3px; margin-bottom: 20px; }
.ct-star { width: 13px; height: 13px; background: var(--accent); clip-path: polygon(50% 0%,61% 35%,98% 35%,68% 57%,79% 91%,50% 70%,21% 91%,32% 57%,2% 35%,39% 35%); }
.ct-testi-text { font-size: 15px; font-weight: 300; line-height: 1.85; color: #aaa; margin-bottom: 28px; }
.ct-testi-author { display: flex; align-items: center; gap: 14px; }
.ct-testi-av { width: 42px; height: 42px; border-radius: 50%; background: var(--accent2); display: flex; align-items: center; justify-content: center; font-family: 'Bebas Neue', Impact, sans-serif; font-size: 16px; color: var(--accent); border: 1px solid rgba(232,255,0,.2); flex-shrink: 0; }
.ct-testi-name { font-size: 15px; font-weight: 600; color: var(--white); letter-spacing: .5px; }
.ct-testi-loc { font-size: 12px; color: var(--muted); letter-spacing: .5px; }

/* ── MARQUEE 2 ── */
.ct-marquee2-wrap { overflow: hidden; background: var(--black); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); padding: 12px 0; white-space: nowrap; }
.ct-marquee2-track { display: inline-flex; animation: ct-marquee2 28s linear infinite; }
@keyframes ct-marquee2 { from { transform: translateX(-50%); } to { transform: translateX(0); } }

/* ── SCROLL REVEAL ── */
.ct-reveal { opacity: 0; transform: translateY(24px); transition: opacity .7s ease, transform .7s ease; }
.ct-reveal.ct-visible { opacity: 1; transform: translateY(0); }
.ct-d1 { transition-delay: .1s; }
.ct-d2 { transition-delay: .2s; }
.ct-d3 { transition-delay: .3s; }

/* ── RESPONSIVE ── */
@media (max-width: 960px) {
  .ct-hero { grid-template-columns: 1fr; }
  .ct-hero-right { min-height: 360px; }
  .ct-hero-left { padding: 60px 28px; }
  .ct-section { padding: 64px 20px; }
  .ct-cat-grid { grid-template-columns: repeat(2, 1fr); }
  .ct-cat-card:nth-child(1) { grid-column: span 2; }
  .ct-prod-grid { grid-template-columns: repeat(2, 1fr); }
  .ct-hiw-grid { grid-template-columns: repeat(2, 1fr); }
  .ct-testi-grid { grid-template-columns: 1fr; }
  .ct-cta { flex-direction: column; padding: 64px 28px; }
  .ct-section-header-row { flex-direction: column; align-items: flex-start; gap: 16px; }
  .ct-hero-stats { gap: 28px; }

  /* ── CATALOG LIST MOBILE FIX ── */
  .ct-coll-row {
    align-items: center;
    padding: 18px 0;
    gap: 0;
  }
  .ct-coll-left {
    gap: 10px;
    flex: 1;
    min-width: 0;
    overflow: hidden;
  }
  .ct-coll-num {
    flex-shrink: 0;
    width: 24px;
  }
  .ct-coll-name {
    font-size: 24px !important;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    min-width: 0;
  }
  .ct-coll-tag {
    display: none;
  }
  .ct-coll-right {
    flex-shrink: 0;
    flex-direction: column;
    align-items: flex-end;
    gap: 2px;
    padding-left: 10px;
  }
  .ct-coll-count {
    font-size: 12px;
    white-space: nowrap;
  }
  .ct-coll-arrow {
    opacity: 1;
    transform: none;
    font-size: 16px;
  }
}
</style>

<div class="ct-page">

  <!-- CUSTOM NAV BAR -->
  <nav class="ct-nav">
    <a href="{{ routes.root_url }}" class="ct-nav-logo">Customized<span>Tees</span></a>

    <div class="ct-nav-links">
      <a href="/collections/all">All Products</a>
      <a href="/collections/T-shirts?filter.p.product_type=Short+Sleeve">Tees</a>
      <a href="/collections/hoodies?filter.p.product_type=Hoodies">Hoodies</a>
      <a href="/collections/all?filter.p.product_type=Sweatshirts">Sweatshirts</a>
      <a href="/collections/shorts?filter.p.product_type=Bottoms">Bottoms</a>
      <a href="/collections/College?filter.p.product_type=College">College</a>
    </div>

    <div class="ct-nav-actions">
      <a href="{{ routes.search_url }}" class="ct-nav-icon header-actions__action" aria-label="Search">
        {{ 'icon-search.svg' | inline_asset_content }}
