}
.ct-cat-img img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; transition: transform .6s ease; }
.ct-cat-img-hint { font-size: var(--text-xs); letter-spacing: var(--tracking-widest); color: var(--border-secondary); text-transform: uppercase; position: relative; z-index: 1; font-family: var(--font-body); font-weight: var(--font-medium); }
.ct-cat-card:hover .ct-cat-img { transform: scale(1.04); }
.ct-cat-card:hover .ct-cat-img img { transform: scale(1.04); }
.ct-cat-overlay {
